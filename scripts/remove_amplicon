import pandas as pd

# 1. Ladda in den stora filen
# Vi använder sep='\t' eftersom det är en TSV-fil
file_path = "data/metadata/NCBI.mine.metagenome.sampleID_full_metadata.tsv"
df = pd.read_csv(file_path, sep='\t')

# 2. TASK 3: Se fördelningen av sekveneringstyper INNAN vi filtrerar
print("--- Distribution of Sequencing Types (Task 3) ---")
print(df['library_strategy'].value_counts())

# 3. TASK 2: Se fördelning per land (för alla prover)
print("\n--- Samples per Country (Task 2) ---")
print(df['country'].value_counts())

# 4. FILTRERING: Behåll endast Shotgun (WGS)
# I ENA kallas shotgun oftast för 'WGS' (Whole Genome Shotgun)
shotgun_df = df[df['library_strategy'] == 'WGS'].copy()

# 5. Spara den filtrerade listan till en ny fil
output_path = "data/metadata/mine_shotgun_only.tsv"
shotgun_df.to_csv(output_path, sep='\t', index=False)

print(f"\nSuccess! Filtered {len(shotgun_df)} shotgun samples to {output_path}")

# 6. TASK 5: Hitta svenska prover
sweden_samples = shotgun_df[shotgun_df['country'].str.contains("Sweden", na=False)]
print("\n--- Potential Swedish Shotgun Samples (Task 5) ---")
print(sweden_samples[['sample_accession', 'run_accession', 'lat', 'lon']])
